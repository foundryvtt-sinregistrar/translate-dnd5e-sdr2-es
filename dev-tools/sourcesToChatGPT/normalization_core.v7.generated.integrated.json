  "regex_rules": [
    {
      "id": "strip_square_brackets",
      "description": "Elimina texto entre corchetes [] (útil para glosarios con anotaciones).",
      "pattern": "\\[[^\\]]*\\]",
      "replacement": "",
      "flags": "g"
    },
    {
      "id": "dc_to_cd",
      "description": "Normaliza DC → CD conservando el número.",
      "pattern": "\\bDC\\s*(\\d+)\\b",
      "replacement": "CD \\1",
      "flags": "gi"
    },
    {
      "id": "feet_to_pies",
      "description": "Normaliza 'X feet' → 'X pies'.",
      "pattern": "\\b(\\d+)\\s*feet\\b",
      "replacement": "\\1 pies",
      "flags": "gi"
    },
    {
      "id": "ft_to_pies",
      "description": "Normaliza 'X ft' → 'X pies'.",
      "pattern": "\\b(\\d+)\\s*ft\\.?\\b",
      "replacement": "\\1 pies",
      "flags": "gi"
    },
    {
      "id": "miles_to_millas",
      "description": "Normaliza 'X mile(s)' → 'X milla(s)'.",
      "pattern": "\\b(\\d+)\\s*miles?\\b",
      "replacement": "\\1 milla(s)",
      "flags": "gi"
    },
    {
      "id": "inches_to_pulgadas",
      "description": "Normaliza 'X inch(es)' → 'X pulgada(s)'.",
      "pattern": "\\b(\\d+)\\s*inches?\\b",
      "replacement": "\\1 pulgada(s)",
      "flags": "gi"
    },
    {
      "id": "pounds_to_libras",
      "description": "Normaliza 'X lb(s)' y 'X pound(s)' → 'X libra(s)'.",
      "pattern": "\\b(\\d+)\\s*(lbs?\\.?|pounds?)\\b",
      "replacement": "\\1 libra(s)",
      "flags": "gi"
    },
    {
      "id": "level_x_spell",
      "description": "Normaliza '1st-level' → 'de nivel 1' (inglés ordinal).",
      "pattern": "\\b(\\d+)(st|nd|rd|th)-level\\b",
      "replacement": "de nivel \\1",
      "flags": "gi"
    },
    {
      "id": "normalize_spaces",
      "description": "Colapsa espacios duplicados.",
      "pattern": "[ \\t]{2,}",
      "replacement": " ",
      "flags": "g"
    },
    {
